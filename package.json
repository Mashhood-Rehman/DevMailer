{
  "name": "devmailer",
  "displayName": "DevMailer",
  "description": "Test your email integrations directly within VS Code using temporary emails.",
  "version": "0.0.1",
  "publisher": "prime-laptops",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devmailer-explorer",
          "title": "DevMailer",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "devmailer-explorer": [
        {
          "type": "webview",
          "id": "devmailer-view",
          "name": "Messages",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "devmailer.refresh",
        "title": "Refresh Emails",
        "icon": "$(refresh)"
      },
      {
        "command": "devmailer.generateNew",
        "title": "Generate New Email",
        "icon": "$(add)"
      },
      {
        "command": "devmailer.manualAuth",
        "title": "DevMailer: Manual Auth (Fallback)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devmailer.refresh",
          "when": "view == devmailer-view",
          "group": "navigation"
        },
        {
          "command": "devmailer.generateNew",
          "when": "view == devmailer-view",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "DevMailer",
      "properties": {
        "devmailer.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for new emails."
        },
        "devmailer.refreshInterval": {
          "type": "number",
          "default": 15,
          "description": "The interval (in seconds) to check for new emails (minimum 5s)."
        },
        "devmailer.backendUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "The base URL of your DevMailer backend (e.g. your Render.com URL)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "server": "npm run dev --prefix backend",
    "dev": "concurrently \"npm run watch\" \"npm run server\"",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}
